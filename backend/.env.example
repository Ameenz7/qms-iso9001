PORT=3000
CORS_ORIGIN=http://localhost:4200

DB_HOST=localhost
DB_PORT=5432
DB_USER=qms
DB_PASSWORD=qms
DB_NAME=qms

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=8h

SUPER_ADMIN_EMAIL=admin@qms.local
SUPER_ADMIN_PASSWORD=admin123

# Outbound email (Resend). Leave RESEND_API_KEY blank to skip email sending —
# invite creation still returns the accept URL so the admin can copy/paste it.
RESEND_API_KEY=
MAIL_FROM=QMS <onboarding@resend.dev>

# Base URL for links embedded in outgoing emails (invite activation etc.)
APP_URL=http://localhost:4200

# ---- Attachment storage ----
# Pick the backend for document uploads. "local" writes to disk, "minio" (or
# "s3") talks to an S3-compatible object store. Docker Compose defaults to
# "minio" with the bundled MinIO container.
STORAGE_DRIVER=local

# Local-disk driver — directory where attachments are written. Must be
# writable by the backend process. Ignored when STORAGE_DRIVER != local.
UPLOAD_DIR=./uploads

# MinIO / S3 driver — used when STORAGE_DRIVER is "minio" or "s3".
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=qms-attachments
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
# "true" for MinIO / most self-hosted gateways; "false" for real AWS S3.
S3_FORCE_PATH_STYLE=true
