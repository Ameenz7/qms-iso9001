PORT=3000
CORS_ORIGIN=http://localhost:4200

DB_HOST=localhost
DB_PORT=5432
DB_USER=qms
DB_PASSWORD=qms
DB_NAME=qms

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=8h

SUPER_ADMIN_EMAIL=admin@qms.local
SUPER_ADMIN_PASSWORD=admin123

# Outbound email (Resend). Leave RESEND_API_KEY blank to skip email sending —
# invite creation still returns the accept URL so the admin can copy/paste it.
RESEND_API_KEY=
MAIL_FROM=QMS <onboarding@resend.dev>

# Base URL for links embedded in outgoing emails (invite activation etc.)
APP_URL=http://localhost:4200

# Local directory where document attachments are written. Must be writable
# by the backend process. In Docker this is bind-mounted to a host volume
# so uploads survive container rebuilds.
UPLOAD_DIR=./uploads
